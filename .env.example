# ELT MCP Server Configuration
# Copy this file to .env and fill in your actual values

# DAG deployment via SSH: MCP Server → Airflow host
# AIRFLOW_REMOTE_HOST=your-airflow-host
# AIRFLOW_REMOTE_USER=airflow
# AIRFLOW_REMOTE_SSH_KEY=~/.ssh/id_ed25519_airflow
# AIRFLOW_REMOTE_PASSWORD=ssh-password    # only if not using key auth
# AIRFLOW_REMOTE_PORT=22
# AIRFLOW_REMOTE_SSH_KEY_PASSPHRASE=    # only if SSH key is passphrase-protected

# AIRFLOW_DAG_FOLDER=/opt/airflow/dags

# ==============================================================================
# SSH — MCP Client (Optional — only needed when Airflow executes BTEQ/TdLoad/TPT
# by SSHing back to this machine. Values are embedded into generated DAG code.)
# ==============================================================================
# MCP_CLIENT_SSH_HOST=your-mcp-client-hostname
# MCP_CLIENT_SSH_USER=your-username
# MCP_CLIENT_SSH_PORT=22
# MCP_CLIENT_SSH_KEY_PATH=~/.ssh/id_ed25519_mcp    # key stored on Airflow worker
# MCP_CLIENT_SSH_PASSWORD=ssh-password    # only if not using key auth

# ==============================================================================
# NOTE: The following settings are wizard-only and must NOT be set in this file:
#   TERADATA_HOST, TERADATA_USERNAME, TERADATA_PASSWORD, TERADATA_PORT, TERADATA_DATABASE
#   AIRFLOW_BASE_URL, AIRFLOW_USERNAME, AIRFLOW_PASSWORD, AIRFLOW_ACCESS_TOKEN
#   AIRBYTE_BASE_URL, AIRBYTE_CLIENT_ID, AIRBYTE_CLIENT_SECRET
# Use the VS Code extension wizard or connections.yaml profiles for those instead.
# ==============================================================================

# ==============================================================================
# MCP SERVER (Optional — logging and behavior)
# ==============================================================================
MCP_LOG_LEVEL=INFO             # DEBUG | INFO | WARNING | ERROR | CRITICAL
# MCP_LOG_FILE=./logs/elt-mcp-server.log
# MCP_FAIL_FAST_ON_STARTUP=false    # true = crash on connectivity failure at startup
# MCP_REDIS_URL=redis://localhost:6379/0    # for distributed circuit breaker

# ==============================================================================
# TTU - Teradata Tools & Utilities (Optional — local TPT/BTEQ execution)
#
# Binary paths are auto-detected from TTU_TTU_VERSION and platform:
#   Windows: C:\Program Files\Teradata\Client\<version>\bin
#   Linux:   /opt/teradata/client/<version>/bin
#   macOS:   /Library/Application Support/Teradata/client/<version>/bin
# If TTU_TTU_VERSION is not set and the default (17.20) is not installed,
# the server scans the install directory and auto-selects the highest
# installed version. Override with explicit *_BINARY_PATH if needed.
# ==============================================================================
# TTU_ENABLED=false
# TTU_TTU_VERSION=17.20
# TTU_TPT_BINARY_PATH=
# TTU_BTEQ_BINARY_PATH=
# TTU_TDLOAD_BINARY_PATH=
# TTU_COMMAND_TIMEOUT=600


